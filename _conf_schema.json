{
  "admin_qqs": {
    "description": "管理员QQ号列表",
    "type": "list",
    "hint": "输入管理员的QQ号，支持多个",
    "default": []
  },
  "ai_config": {
    "description": "AI 模型配置",
    "type": "object",
    "items": {
      "base_url": {
        "description": "API Base URL",
        "type": "string",
        "hint": "例如：https://api.deepseek.com/v1"
      },
      "api_key": {
        "description": "API Key",
        "type": "string",
        "hint": "输入你的 API Key",
        "obvious_hint": true
      },
      "model": {
        "description": "模型名称",
        "type": "string",
        "default": "deepseek-chat",
        "hint": "例如：deepseek-chat、gpt-3.5-turbo"
      }
    }
  },
  "rate_limit": {
    "description": "频率限制配置",
    "type": "object",
    "items": {
      "window_minutes": {
        "description": "限制时间窗口（分钟）",
        "type": "int",
        "default": 10
      },
      "max_requests_per_window": {
        "description": "窗口内最大请求次数（基于QQ号全局限制）",
        "type": "int",
        "default": 3
      },
      "daily_max": {
        "description": "每日最大请求次数（基于QQ号全局限制）",
        "type": "int",
        "default": 20
      }
    }
  },
  "preset_games": {
    "description": "预设游戏列表",
    "type": "list",
    "hint": "输入游戏名称，支持多个（每行一个）",
    "default": ["原神", "星露谷物语", "艾尔登法环", "塞尔达传说：王国之泪", "博德之门3"]
  },
  "search_config": {
    "description": "联网搜索配置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否启用联网搜索",
        "type": "bool",
        "default": true
      },
      "result_count": {
        "description": "采用搜索结果条数",
        "type": "int",
        "default": 3,
        "hint": "搜索后采用多少条搜索结果的信息（1-10）"
      },
      "summarize_enabled": {
        "description": "是否启用搜索汇总",
        "type": "bool",
        "default": true,
        "hint": "开启后通过 AI 对搜索结果进行分析整理，关闭则直接使用原始搜索结果"
      },
      "summarize_max_chars": {
        "description": "搜索汇文字数限制",
        "type": "int",
        "default": 150,
        "hint": "AI 生成的搜索汇总文章的最大字数（50-500）"
      },
      "timeout_ms": {
        "description": "搜索超时时间（毫秒）",
        "type": "int",
        "default": 8000
      }
    }
  },
  "whitelist_groups": {
    "description": "白名单群聊列表",
    "type": "list",
    "hint": "留空表示所有群聊均可使用。填写群号后，仅这些群聊可使用小作文功能",
    "default": []
  },
  "whitelist_privates": {
    "description": "白名单私聊列表",
    "type": "list",
    "hint": "留空表示所有私聊均可使用。填写QQ号后，仅这些私聊可使用小作文功能",
    "default": []
  },
  "show_generation_stats": {
    "description": "生成后发送统计信息",
    "type": "bool",
    "hint": "开启后每次生成小作文后会额外发送一条生成信息（模型、耗时、Token、搜索汇总等）",
    "default": true
  }
}
